if (mcol %in% actualNames) {
mean(results$values[, mcol], na.rm = TRUE)
} else {
Inf
}
})
rmse_means
rmse_means <- sapply(results$models, function(model) {
mcol <- paste(sep = "~", model, "RMSE")
for (col in mcol) {
mean(results$values[, mcol], na.rm = TRUE)
}
})
